// ── VIDEO WATCH PROGRESS (granular per-video tracking) ──

model VideoWatchProgress {
  id                      String    @id @default(uuid())
  userId                  String
  contentId               String
  watchedSeconds          Float     @default(0)
  totalDurationSeconds    Float     @default(0)
  furthestPositionSeconds Float     @default(0)
  watchPercentage         Float     @default(0)
  isCompleted             Boolean   @default(false)
  completedAt             DateTime?
  completionThreshold     Float     @default(0.90)
  playCount               Int       @default(0)
  pauseCount              Int       @default(0)
  seekCount               Int       @default(0)
