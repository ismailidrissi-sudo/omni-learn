// omnilearn.space — Core Database Schema
// PostgreSQL 16 + pgvector | Afflatus Consulting Group
// Every Skill. One Space.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector(map: "vector")]
}

// ── ENUMS ──

// Subscription tiers: 0=Explorer (Free), 1=Specialist, 2=Visionary, 3=Nexus (Enterprise)
enum SubscriptionPlan {
  EXPLORER
  SPECIALIST
  VISIONARY
  NEXUS
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum ContentType {
  COURSE
  MICRO_LEARNING
  PODCAST
  DOCUMENT
  IMPLEMENTATION_GUIDE
  QUIZ_ASSESSMENT
  GAME
  VIDEO
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
  EXPIRED
}

enum StepProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum CertificateGrade {
  PASS
  MERIT
  DISTINCTION
}

// ── B2B ENUMS ──

enum ContractStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  EXPIRED
  CANCELLED
}

enum SsoProviderType {
  SAML_2_0
  OIDC
  LINKEDIN_OIDC
}

enum UserGroupType {
  COHORT
  DEPARTMENT
  ROLE
  CUSTOM
}

enum UserType {
  TRAINEE
  TRAINER
  COMPANY_ADMIN
}

enum OrgApprovalStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

/// Unified approval queue (plan upgrade, company join, private-label)
enum ApprovalRequestType {
  PLAN_UPGRADE
  COMPANY_JOIN
  PRIVATE_LABEL
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Canonical account gate (see also orgApprovalStatus for legacy company join)
enum UserAccountStatus {
  ACTIVE
  PENDING_PLAN
  PENDING_COMPANY
  SUSPENDED
}

enum DeviceType {
  DESKTOP
  MOBILE
  TABLET
  UNKNOWN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

// ── INDUSTRIES (seed reference) ──

model Industry {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  sector    String?
  createdAt DateTime @default(now())

  tenants Tenant[]
}

// ── DEPARTMENTS (seed reference) ──

model Department {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())

  users User[]
}

// ── POSITIONS (seed reference) ──

model Position {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())

  users User[]
}

// ── USERS (company users with department/position) ──

model User {
  id            String           @id @default(uuid())
  email         String           @unique
  name          String
  passwordHash  String?          // For email/password signup (bcrypt)
  emailVerified Boolean         @default(false)
  emailVerifyToken String?      // Token for email confirmation
  emailVerifyExpiresAt DateTime? // Token expiry
  passwordResetTokenHash String? @db.VarChar(128) // bcrypt hash of one-time reset token
  passwordResetExpiresAt DateTime?
  departmentId  String?
  positionId    String?
  tenantId      String?
  externalId    String?
  linkedinProfileUrl String?    // For recommendation optimization
  linkedinAccessToken String?   // Encrypted; for LinkedIn contacts import (referral system)
  profileComplete Boolean       @default(false)  // Onboarding completed
  planId        SubscriptionPlan @default(EXPLORER)
  billingCycle  BillingCycle?    // null for free/enterprise
  sectorFocus   String?          // For Specialist: Biotech, Food Safety, AI, etc.
  stripeCustomerId String?       // Stripe customer ID for billing
  stripeSubscriptionId String?  // Active subscription ID
  isAdmin            Boolean      @default(false)  // Platform admin — grants all RBAC roles + trainer + approval rights
  trainerRequested   Boolean      @default(false)  // User requested to be a trainer (content creator)
  trainerApprovedAt DateTime?    // When set, user has INSTRUCTOR role and can create content
  userType           UserType?              // Trainee, Trainer, or Company Admin — selected during profile completion
  orgApprovalStatus  OrgApprovalStatus @default(NONE) // Org affiliation approval by company admin
  companyAdminRequested  Boolean  @default(false)  // User requested company admin role (pending platform admin approval)
  companyAdminApprovedAt DateTime?  // When set, user has COMPANY_ADMIN role
  gender        Gender?
  dateOfBirth   DateTime?
  country       String?
  countryCode   String?          @db.VarChar(3)
  city          String?
  timezone      String?          @db.VarChar(50)
  phoneNumber   String?
  accountStatus UserAccountStatus @default(ACTIVE)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  department Department? @relation(fields: [departmentId], references: [id])
  position   Position?  @relation(fields: [positionId], references: [id])
  tenant     Tenant?    @relation(fields: [tenantId], references: [id])

  requestedApprovals ApprovalRequest[] @relation("ApprovalRequestRequester")
  reviewedApprovals  ApprovalRequest[] @relation("ApprovalRequestReviewer")

  groupMemberships         UserGroupMembership[]
  userTags                 UserTag[]
  seatAssignments          SeatAssignment[]
  contentUserAssignments   ContentUserAssignment[]
  createdContentItems        ContentItem[]            @relation("ContentCreatedBy")
  trainerProfile           TrainerProfile?
  videoWatchProgress       VideoWatchProgress[]
  emailLogs                EmailLog[]
  userEmailPreferences     UserEmailPreference[]
  userContentInteractions  UserContentInteraction[]
  sessions                 UserSession[]
  contentAccessLogs        ContentAccessLog[]
}

// ── TENANTS (rich company profile) ──

model Tenant {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique
  industryId       String?
  logoUrl          String?
  linkedinProfileUrl String?    // Company LinkedIn page
  companyProfileComplete Boolean @default(false)  // Profile data for recommendations
  language         String?  @default("en")
  status           String?  @default("ACTIVE")
  targetMarkets    Json?    @default("[]")
  productsServices Json?    @default("[]")
  certifications   Json?    @default("[]")
  staffingLevel    String?
  internalErp      String?
  settings         Json?    @default("{}")
  /// INDIVIDUAL | COMPANY | PRIVATE_LABEL
  tenantKind       String   @default("INDIVIDUAL") @db.VarChar(30)
  privateLabelConfig Json?  @default("{}")
  /// For PRIVATE_LABEL: PENDING until super_admin approves; else ACTIVE | SUSPENDED
  tenantApprovalStatus String @default("ACTIVE") @db.VarChar(20)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  industry            Industry?             @relation(fields: [industryId], references: [id])
  domains             Domain[]
  learningPaths       LearningPath[]
  certificateTemplates CertificateTemplate[]
  branding            TenantBranding?
  users               User[]
  privateContent      ContentItem[]         // Nexus: tenant-specific content

  contracts                 B2BContract[]
  userGroups                UserGroup[]
  tags                      Tag[]
  ssoConfigs                TenantSsoConfig[]
  contentTenantAssignments   ContentTenantAssignment[]
  emailBranding              EmailBranding?
  emailSchedules             EmailSchedule[]
  emailCampaigns             EmailCampaign[]
  approvalRequests           ApprovalRequest[]
  geoAnalyticsRollups        GeoAnalyticsRollup[]

  @@index([industryId])
}

model ApprovalRequest {
  id          String                @id @default(uuid())
  tenantId    String
  type        ApprovalRequestType
  status      ApprovalRequestStatus @default(PENDING)
  requesterId String
  reviewerId  String?
  payload     Json                  @default("{}")
  reviewNote  String?               @db.Text
  createdAt   DateTime              @default(now())
  reviewedAt  DateTime?

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requester User   @relation("ApprovalRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  reviewer  User?  @relation("ApprovalRequestReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([type, status])
  @@map("approval_requests")
}

// ── DYNAMIC DOMAINS (admin-created, NOT enums) ──

model Domain {
  id          String   @id @default(uuid())
  tenantId    String
  name        String   @db.VarChar(100)
  slug        String   @db.VarChar(100)
  description String?  @db.Text
  icon        String?  @db.VarChar(10)
  color       String   @db.VarChar(7)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  certificateTemplate  CertificateTemplate?
  learningPaths        LearningPath[]
  contentItems         ContentItem[]

  @@unique([tenantId, slug])
  @@index([tenantId, isActive])
  @@map("domains")
}

// ── LEARNING PATHS ──

model LearningPath {
  id          String   @id @default(uuid())
  tenantId    String
  domainId    String
  name        String
  slug        String
  difficulty  String?
  description String?
  isPublished Boolean  @default(false)
  settings    Json?    @default("{}")

  availablePlans        Json      @default("[\"EXPLORER\",\"SPECIALIST\",\"VISIONARY\",\"NEXUS\"]") // Which subscription plans can access this
  availableInEnterprise Boolean   @default(false) // Available in company white-label academies

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  domain     Domain               @relation(fields: [domainId], references: [id], onDelete: Restrict)
  steps      LearningPathStep[]
  enrollments PathEnrollment[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([domainId])
}

model LearningPathStep {
  id            String   @id @default(uuid())
  pathId        String
  contentItemId String
  stepOrder     Int
  isRequired    Boolean  @default(true)
  unlockAfterId String?  // Self-reference for prerequisite
  timeGateHours Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  path         LearningPath       @relation(fields: [pathId], references: [id], onDelete: Cascade)
  contentItem  ContentItem        @relation(fields: [contentItemId], references: [id], onDelete: Restrict)
  unlockAfter  LearningPathStep?  @relation("StepPrerequisite", fields: [unlockAfterId], references: [id])
  unlockedBy   LearningPathStep[] @relation("StepPrerequisite")
  progress     PathStepProgress[]

  @@unique([pathId, stepOrder])
  @@index([pathId])
  @@index([contentItemId])
}

// ── CONTENT ITEMS (with pgvector embeddings) ──

model ContentItem {
  id             String      @id @default(uuid())
  type           ContentType
  title          String
  description    String?     @db.Text  // Rich description of the content
  domainId       String?     // Optional FK to domain
  mediaId        String?
  durationMinutes Int?
  metadata       Json?       @default("{}")  // Type-specific metadata (transcript, SCORM, etc.)
  embedding      Unsupported("vector(1536)")?  // pgvector for AI recommendations
  accessLevel    Int         @default(0)  // 0=Foundational (Free), 1=Sector-specific, 2=All-access
  sectorTag      String?     // Biotech, Food Safety, AI, etc. — for Specialist tier filtering
  tenantId       String?     // For Nexus: private enterprise content
  isFoundational Boolean    @default(false)  // Tagged for Explorer (Free) tier

  availablePlans        Json      @default("[\"EXPLORER\",\"SPECIALIST\",\"VISIONARY\",\"NEXUS\"]") // Which subscription plans can access this
  availableInEnterprise Boolean   @default(false) // Available in company white-label academies

  language              String    @default("en") // Content language (en, fr, ar, …)

  videoIsMicrolearning Boolean  @default(false)
  videoDurationSeconds Int?     // Precise duration in seconds for video content

  createdById    String?     // Trainer / author who created this item (admin isolation)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  createdBy              User?                    @relation("ContentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  domain                 Domain?                  @relation(fields: [domainId], references: [id])
  tenant                 Tenant?                  @relation(fields: [tenantId], references: [id])
  pathSteps              LearningPathStep[]
  courseSections         CourseSection[]  // For type=COURSE: Udemy-style curriculum
  courseEnrollments      CourseEnrollment[]
  tenantAssignments      ContentTenantAssignment[] // When empty = all companies
  userAssignments        ContentUserAssignment[]   // When empty = all users
  contentAccessLogs      ContentAccessLog[]

  @@index([tenantId])
  @@index([createdById])
  @@index([sectorTag])
  @@index([isFoundational])
}

model ContentTenantAssignment {
  id        String   @id @default(uuid())
  contentId String
  tenantId  String
  createdAt DateTime @default(now())

  content ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([contentId, tenantId])
  @@index([contentId])
  @@index([tenantId])
}

model ContentUserAssignment {
  id        String   @id @default(uuid())
  contentId String
  userId    String
  createdAt DateTime @default(now())

  content ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contentId, userId])
  @@index([contentId])
  @@index([userId])
}

// ── COURSE CURRICULUM (Udemy-style: sections → lectures, videos, docs, quizzes) ──

enum CourseItemType {
  VIDEO
  AUDIO
  DOCUMENT
  QUIZ
  ARTICLE
  CODING_EXERCISE  // Udemy-style: practical coding exercises
}

model CourseSection {
  id          String   @id @default(uuid())
  courseId    String   // ContentItem.id where type=COURSE
  title       String
  learningGoal String? @db.Text  // "What will students achieve at the end of this section?"
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course  ContentItem        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  items   CourseSectionItem[]

  @@index([courseId])
}

model CourseSectionItem {
  id            String        @id @default(uuid())
  sectionId     String
  itemType      CourseItemType
  title         String
  sortOrder     Int           @default(0)
  durationMinutes Int?         // For VIDEO
  contentUrl    String?       // Video URL, document URL, etc.
  metadata      Json?         @default("{}")  // Quiz questions, article content, etc.

  videoSourceType      String?   // 'youtube' | 'upload' | 'direct' | 'vimeo'
  videoOriginalUrl     String?   // Original URL before resolution
  videoStreamId        String?   // Resolved video stream ID for proxy
  videoDurationSeconds Int?      // Precise duration in seconds
  videoIsMicrolearning Boolean   @default(false)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  section  CourseSection              @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress CourseSectionItemProgress[]

  @@index([sectionId])
}

// ── ENROLLMENTS & PROGRESS ──

model PathEnrollment {
  id         String           @id @default(uuid())
  userId     String
  pathId     String
  status     EnrollmentStatus @default(ACTIVE)
  progressPct Int             @default(0)
  deadline   DateTime?
  completedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  path       LearningPath      @relation(fields: [pathId], references: [id], onDelete: Cascade)
  stepProgress PathStepProgress[]
  certificates IssuedCertificate[]

  @@unique([userId, pathId])
  @@index([userId])
  @@index([pathId])
}

model PathStepProgress {
  id           String             @id @default(uuid())
  enrollmentId String
  stepId       String
  status       StepProgressStatus @default(NOT_STARTED)
  timeSpent    Int?               // seconds
  score        Int?
  completedAt  DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  enrollment PathEnrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  step       LearningPathStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, stepId])
  @@index([enrollmentId])
  @@index([stepId])
}

model CourseEnrollment {
  id          String           @id @default(uuid())
  userId      String
  courseId     String           // ContentItem.id where type=COURSE
  status      EnrollmentStatus @default(ACTIVE)
  progressPct Int              @default(0)
  deadline    DateTime?
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  course       ContentItem                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  itemProgress CourseSectionItemProgress[]
  certificates IssuedCertificate[]

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model CourseSectionItemProgress {
  id            String             @id @default(uuid())
  enrollmentId  String
  sectionItemId String
  status        StepProgressStatus @default(NOT_STARTED)
  timeSpent     Int?               // seconds
  score         Int?
  completedAt   DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  enrollment  CourseEnrollment  @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  sectionItem CourseSectionItem @relation(fields: [sectionItemId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, sectionItemId])
  @@index([enrollmentId])
  @@index([sectionItemId])
}

// ── CERTIFICATES ──

model CertificateTemplate {
  id             String   @id @default(uuid())
  tenantId       String
  domainId       String   @unique  // 1:1 with Domain
  templateName   String
  themeConfig    Json?    @default("{}")
  elementsConfig Json?    @default("{}")
  signatories    Json?    @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  domain             Domain              @relation(fields: [domainId], references: [id], onDelete: Cascade)
  issuedCertificates IssuedCertificate[]

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  @@unique([tenantId, domainId])
  @@index([tenantId])
  @@map("certificate_templates")
}

model IssuedCertificate {
  id                   String          @id @default(uuid())
  templateId           String
  enrollmentId         String?         // PathEnrollment FK (null when course cert)
  courseEnrollmentId   String?         // CourseEnrollment FK (null when path cert)
  verifyCode           String          @unique
  pdfUrl               String?
  grade                CertificateGrade?
  issuedAt             DateTime        @default(now())

  template         CertificateTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  enrollment       PathEnrollment?     @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  courseEnrollment CourseEnrollment?   @relation(fields: [courseEnrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId])
  @@index([courseEnrollmentId])
  @@index([verifyCode])
}

// ── GAMIFICATION ──

model UserPoints {
  id          String   @id @default(uuid())
  userId      String   @unique
  points      Int      @default(0)
  lastUpdated DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model Badge {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  icon        String
  description String?
  criteria    Json?    @default("{}")
  createdAt   DateTime @default(now())

  userBadges UserBadge[]
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

model UserStreak {
  id             String    @id @default(uuid())
  userId         String    @unique
  currentStreak  Int       @default(0)
  longestStreak Int       @default(0)
  lastActivityAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ── xAPI (Learning Record Store) ──

model XapiStatement {
  id        String   @id @default(uuid())
  statement Json     // xAPI statement: actor, verb, object, result, context
  storedAt  DateTime @default(now())

  @@index([storedAt])
}

// ── PHASE 4: DISCUSSION FORUMS ──

model ForumChannel {
  id          String   @id @default(uuid())
  name        String
  slug        String
  contentId   String?
  pathId      String?
  tenantId    String?
  description String?
  isLocked    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  topics ForumTopic[]
}

model ForumTopic {
  id        String   @id @default(uuid())
  channelId String
  authorId  String
  title     String
  body      String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channel ForumChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  posts   ForumPost[]
}

model ForumPost {
  id        String   @id @default(uuid())
  topicId   String
  authorId  String
  body      String
  status    String   @default("VISIBLE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topic ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
}

model ForumModeration {
  id          String   @id @default(uuid())
  targetType  String
  targetId    String
  action      String
  moderatorId String
  reason      String?
  createdAt   DateTime @default(now())

  @@index([targetType, targetId])
}

// ── PHASE 4: COURSE REVIEWS & RATINGS ──

model CourseReview {
  id           String   @id @default(uuid())
  contentId    String
  userId       String
  rating       Int
  review       String?
  helpfulCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([contentId, userId])
  @@index([contentId])
  @@index([userId])
}

// ── PHASE 4: COMPANY / TENANT BRANDING ──

model TenantBranding {
  id             String   @id @default(uuid())
  tenantId       String   @unique
  logoUrl        String?
  /// Raster/vector bytes served at GET /company/tenants/:tenantId/logo (takes precedence over logoUrl for display)
  logoData       Bytes?
  logoMimeType   String?  @db.VarChar(127)
  faviconUrl     String?
  primaryColor   String?  @default("#6B4E9A")
  secondaryColor String?  @default("#8D8D8D")
  accentColor    String?
  appName        String?
  tagline        String?
  loginBgUrl     String?
  emailLogoUrl   String?
  fontFamily     String?
  navStyle       String?  @default("topbar") // "topbar" | "sidebar"
  customCss      String?
  settings       Json?    @default("{}")
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ── PHASE 1 B2B: SEAT MANAGEMENT & CONTRACTS ──

model B2BContract {
  id            String         @id @default(uuid())
  tenantId      String
  name          String
  seatsTotal    Int            // Total seats purchased in this contract block
  seatsUsed     Int            @default(0) // Consumed seats (denormalized for fast checks)
  startDate     DateTime
  endDate       DateTime
  status        ContractStatus @default(DRAFT)
  planType      String?        // e.g., "ENTERPRISE", "PROFESSIONAL", "STARTER"
  billingCycle  String?        // MONTHLY, QUARTERLY, ANNUAL
  externalRef   String?        // External CRM/ERP reference
  metadata      Json?         @default("{}")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  seatAssignments SeatAssignment[]

  @@index([tenantId])
  @@index([status])
  @@index([endDate])
}

model SeatAssignment {
  id         String    @id @default(uuid())
  contractId String
  userId     String
  assignedAt DateTime  @default(now())
  revokedAt  DateTime?
  assignedBy String?   // Admin who assigned the seat
  metadata   Json?     @default("{}")

  contract B2BContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contractId, userId])
  @@index([contractId])
  @@index([userId])
}

// ── PHASE 1 B2B: USER GROUPS & TAGS ──

model UserGroup {
  id          String       @id @default(uuid())
  tenantId    String
  name        String
  slug        String
  type        UserGroupType @default(CUSTOM)
  description String?
  settings    Json?         @default("{}") // Custom roles, permissions overrides
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members  UserGroupMembership[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([type])
}

model UserGroupMembership {
  id        String   @id @default(uuid())
  groupId   String
  userId    String
  role      String?  // Optional custom role within group (e.g., "LEAD", "MEMBER")
  joinedAt  DateTime @default(now())
  expiresAt DateTime?
  metadata  Json?    @default("{}")

  group UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

model Tag {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  slug      String
  color     String?  @default("#6B4E9A")
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userTags UserTag[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model UserTag {
  id         String   @id @default(uuid())
  userId     String
  tagId      String
  assignedAt DateTime @default(now())
  assignedBy String?
  metadata   Json?    @default("{}")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([userId, tagId])
  @@index([userId])
  @@index([tagId])
}

// ── PHASE 1 B2B: MULTI-SSO & IDENTITY ──

model TenantSsoConfig {
  id           String         @id @default(uuid())
  tenantId     String
  provider     SsoProviderType
  isEnabled    Boolean        @default(false)
  entityId     String?        // SAML: Entity ID; OIDC: Issuer
  metadataUrl  String?        // SAML: IdP metadata URL
  clientId     String?        // OIDC: Client ID
  clientSecret String?        // OIDC: Client secret (encrypted at rest)
  config       Json?          @default("{}") // Provider-specific config (SAML attrs, OIDC scopes, etc.)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@index([tenantId])
}

// ── PHASE 4: ANALYTICS EVENTS ──

model AnalyticsEvent {
  id        String   @id @default(uuid())
  eventType String
  userId    String?
  tenantId  String?
  pathId    String?
  contentId String?
  payload   Json?    @default("{}")
  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([userId])
  @@index([tenantId])
  @@index([createdAt])
}

// ── DEEP ANALYTICS: USER SESSIONS ──

model UserSession {
  id               String     @id @default(uuid())
  userId           String
  tenantId         String?
  fingerprint      String?
  ipAddress        String?
  userAgent        String?    @db.Text
  deviceType       DeviceType @default(DESKTOP)
  browserName      String?
  browserVersion   String?
  osName           String?
  osVersion        String?
  screenResolution String?
  language         String?
  country          String?
  countryCode      String?
  city             String?
  region           String?
  latitude         Float?
  longitude        Float?
  continent        String?    @db.VarChar(30)
  startedAt        DateTime   @default(now())
  endedAt          DateTime?
  durationSeconds  Int        @default(0)
  isActive         Boolean    @default(true)

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  pageViews PageView[]

  @@index([userId])
  @@index([tenantId])
  @@index([startedAt])
  @@index([deviceType])
  @@index([country])
  @@index([countryCode])
  @@index([continent, startedAt])
  @@index([isActive])
  @@map("user_sessions")
}

/// Per-content access with geography (rollup source + live activity).
model ContentAccessLog {
  id                String   @id @default(uuid())
  userId            String
  contentId         String
  deviceType        String   @default("web") @db.VarChar(20)
  ipAddress         String?  @db.VarChar(45)
  userAgent         String?  @db.Text
  screenshotAttempt Boolean  @default(false)
  createdAt         DateTime @default(now())

  country     String?  @db.VarChar(100)
  countryCode String?  @db.VarChar(3)
  city        String?  @db.VarChar(100)
  region      String?  @db.VarChar(100)
  latitude    Float?
  longitude   Float?
  continent   String?  @db.VarChar(30)

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  content ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([country, createdAt])
  @@index([countryCode])
  @@index([continent, createdAt])
  @@index([contentId])
  @@index([createdAt])
  @@map("content_access_logs")
}

/// Pre-aggregated geographic metrics per tenant (filled by BullMQ jobs).
model GeoAnalyticsRollup {
  id            String   @id @default(uuid())
  tenantId      String
  period        String   @db.VarChar(10)
  periodStart   DateTime
  country       String   @db.VarChar(100)
  countryCode   String   @db.VarChar(3)
  /// Empty string = country-level row; non-empty = city-level rollup bucket
  city          String   @default("") @db.VarChar(100)
  region        String?  @db.VarChar(100)

  activeUsers        Int    @default(0)
  newRegistrations Int    @default(0)
  contentViews     Int    @default(0)
  courseCompletions Int   @default(0)
  pathCompletions  Int    @default(0)
  certsIssued      Int    @default(0)
  totalTimeSpentMin Int   @default(0)
  quizAttempts     Int    @default(0)
  avgQuizScore     Float?

  webSessions     Int @default(0)
  iosSessions     Int @default(0)
  androidSessions Int @default(0)

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, period, periodStart, country, city])
  @@index([tenantId, period, periodStart])
  @@index([countryCode, period])
  @@map("geo_analytics_rollups")
}

model PageView {
  id              String   @id @default(uuid())
  sessionId       String
  userId          String
  path            String
  title           String?
  contentId       String?
  contentType     String?
  durationSeconds Int      @default(0)
  createdAt       DateTime @default(now())

  session UserSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
  @@index([contentId])
  @@index([createdAt])
  @@map("page_views")
}

