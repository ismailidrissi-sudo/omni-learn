  fontFamily      String    @default("Inter, system-ui, sans-serif")
  fontFamilyAr    String    @default("Noto Sans Arabic, Segoe UI, Arial, sans-serif")
  buttonStyle     Json      @default("{\"borderRadius\": \"8px\", \"padding\": \"12px 24px\", \"fontWeight\": \"600\"}")
  senderName      String    @default("OmniLearn") @db.VarChar(255)
  senderEmail     String    @default("noreply@omnilearn.space") @db.VarChar(255)
  replyToEmail    String?   @db.VarChar(255)
  footerText      String?   @db.Text
