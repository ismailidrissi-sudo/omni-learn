// ── TRAINER PUBLIC PROFILES ──

enum TrainerProfileStatus {
  DRAFT
  PUBLISHED
  SUSPENDED
}

model TrainerProfile {
  id               String               @id @default(uuid())
  userId           String               @unique
  status           TrainerProfileStatus  @default(DRAFT)

  headline         String?              @db.VarChar(200)
  bio              String?              @db.Text
  photoUrl         String?
  bannerUrl        String?
  resumeUrl        String?

  specializations  Json?                @default("[]")
  certifications   Json?                @default("[]")
  distinctions     Json?                @default("[]")
  languages        Json?                @default("[]")
  socialLinks      Json?                @default("{}")
  education        Json?                @default("[]")
  experience       Json?                @default("[]")

