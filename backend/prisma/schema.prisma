}

// ── REFERRAL SYSTEM ──

enum ReferralStatus {
  PENDING
  SIGNED_UP
  CONVERTED
  EXPIRED
}

enum RewardStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

model ReferralCode {
  id        String   @id @default(uuid())
  userId    String
  code      String   @unique
  label     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  referrals   Referral[]
  invitations ReferralInvitation[]

  @@index([userId])
  @@index([code])
}

model Referral {
  id               String         @id @default(uuid())
  referralCodeId   String
  referrerId       String
  referredUserId   String?
  referredEmail    String
  status           ReferralStatus @default(PENDING)
  channel          String?
  convertedAt      DateTime?
  signedUpAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  referralCode ReferralCode @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)

  @@unique([referralCodeId, referredEmail])
  @@index([referrerId])
  @@index([referredUserId])
  @@index([referredEmail])
  @@index([status])
  @@index([createdAt])
}

model ReferralReward {
  id           String           @id @default(uuid())
  userId       String
  referralId   String?
  rewardType   String
  grantedPlan  SubscriptionPlan
  durationDays Int
  status       RewardStatus     @default(ACTIVE)
  startsAt     DateTime         @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?
  metadata     Json?            @default("{}")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([userId])
  @@index([referralId])
  @@index([status])
  @@index([expiresAt])
}

model ReferralInvitation {
  id             String   @id @default(uuid())
  referralCodeId String
  senderUserId   String
  recipientEmail String
  recipientName  String?
  source         String   @default("manual")
  sentAt         DateTime @default(now())
  openedAt       DateTime?
  clickedAt      DateTime?
  metadata       Json?    @default("{}")

  referralCode ReferralCode @relation(fields: [referralCodeId], references: [id], onDelete: Cascade)

  @@unique([referralCodeId, recipientEmail])
  @@index([senderUserId])
  @@index([recipientEmail])
  @@index([sentAt])
}

// ── PHASE 4: SCIM PROVISIONING ──

model ScimProvisioningLog {
  id           String   @id @default(uuid())
  operation    String
  resourceType String
  externalId   String?
  payload      Json?
  status       String   @default("PENDING")
  errorMsg     String?
  createdAt    DateTime @default(now())

  @@index([operation])
  @@index([resourceType])
}

// ── ENTERPRISE: TRAINING ASSIGNMENTS (Compliance) ──

enum AssignmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

model TrainingAssignment {
  id           String           @id @default(uuid())
  tenantId     String
  contentId    String?
  pathId       String?
  assigneeType String           // "ALL", "GROUP", "USER"
  assigneeId   String?          // groupId or userId (null for ALL)
  dueDate      DateTime
