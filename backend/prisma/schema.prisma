  @@index([slug])
  @@map("trainer_profiles")
}

// ── EMAIL SYSTEM ──

enum EmailStatus {
  PENDING
  SENDING
  SENT
  FAILED
  SCHEDULED
  CANCELLED
}

enum EmailPriorityLevel {
  CRITICAL // 0 — password resets, 2FA (bypasses daily limit)
  HIGH     // 1 — welcome, enrollment confirmation
  NORMAL   // 2 — notifications, reminders
  LOW      // 3 — marketing, digests
}

enum OverflowStrategy {
  SCHEDULE_NEXT_DAY
  DROP
  QUEUE_HOLD
}

model EmailConfig {
  id                  String           @id @default(uuid())
  provider            String           @default("resend") @db.VarChar(20)
  apiKey              String           @db.Text
  apiKeyLastFour      String?          @db.VarChar(5)
  defaultFromName     String           @default("OmniLearn") @db.VarChar(100)
  defaultFromEmail    String           @default("noreply@omnilearn.space") @db.VarChar(255)
  defaultReplyTo      String?          @db.VarChar(255)
  dailySendLimit      Int              @default(100)
  rateLimitPerSecond  Int              @default(10)
  overflowStrategy    OverflowStrategy @default(SCHEDULE_NEXT_DAY)
  overflowSendHour    Int              @default(6)
  isActive            Boolean          @default(true)
  lastVerifiedAt      DateTime?
  updatedBy           String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@map("email_config")
}

model EmailQueue {
  id            String             @id @default(uuid())
  toEmail       String             @db.VarChar(255)
  toName        String?            @db.VarChar(255)
  fromEmail     String?            @db.VarChar(255)
  fromName      String?            @db.VarChar(100)
  replyTo       String?            @db.VarChar(255)
  subject       String             @db.VarChar(500)
  htmlBody      String             @db.Text
  textBody      String?            @db.Text
  emailType     String             @db.VarChar(50)
  priority      EmailPriorityLevel @default(NORMAL)
  status        EmailStatus        @default(PENDING)
  scheduledFor  DateTime?
  scheduledAfter DateTime?         // Rate-limit / deferred send — processor skips until <= now
  dayBucket     DateTime           @default(now()) @db.Date
  resendId      String?            @db.VarChar(100)
  sentAt        DateTime?
  attempts      Int                @default(0)
  maxAttempts   Int                @default(3)
  lastError     String?            @db.Text
  nextRetryAt   DateTime?
  triggeredBy   String?            @db.VarChar(100)
  userId        String?
  idempotencyKey String?           @unique @db.VarChar(255)
  eventType     String?            @db.VarChar(100)
  metadata      Json               @default("{}")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  emailLog      EmailLog?

  @@index([status, priority, createdAt])
  @@index([scheduledFor])
  @@index([dayBucket, status])
  @@index([nextRetryAt])
  @@index([scheduledAfter])
  @@map("email_queue")
}

model EmailDailyStats {
  dayBucket              DateTime @id @db.Date
  sentCount              Int      @default(0)
  failedCount            Int      @default(0)
  scheduledOverflowCount Int      @default(0)
  updatedAt              DateTime @updatedAt

  @@map("email_daily_stats")
}

model EmailTemplate {
  id              String   @id @default(uuid())
  slug            String   @db.VarChar(100)
  name            String   @db.VarChar(200)
  subjectTemplate String   @db.VarChar(500)
  htmlTemplate    String   @db.Text
  textTemplate    String?  @db.Text
  variables       Json     @default("[]")
  language        String   @default("en") @db.VarChar(10)
  eventType       String?  @db.VarChar(100)
  version         Int      @default(1)
  isActive        Boolean  @default(true)
  updatedBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([slug, language, version])
  @@map("email_templates")
}

/// Admin-managed provider row (future: UI switches active provider; until then use EmailConfig + env)
model EmailProviderConfig {
  id                    String    @id @default(uuid())
  providerType          String    @db.VarChar(20) // smtp | resend
  isActive              Boolean   @default(false)
  displayName           String    @db.VarChar(200)

  smtpHost              String?
  smtpPort              Int?      @default(587)
  smtpUsername          String?
  smtpPasswordEncrypted String?   @db.Text
  smtpUseTls            Boolean?  @default(true)
  smtpUseSsl            Boolean?  @default(false)
  smtpFromEmail         String?
  smtpFromName          String?

  resendApiKeyEncrypted String?   @db.Text
  resendFromDomain      String?

  sendLimitPerMinute    Int       @default(10)
  sendLimitPerHour      Int       @default(100)
  sendLimitPerDay       Int       @default(500)

  emailsSentThisMinute  Int       @default(0)
  emailsSentThisHour    Int       @default(0)
  emailsSentToday       Int       @default(0)
  minuteResetAt         DateTime?
  hourResetAt           DateTime?
  dayResetAt            DateTime?

  lastTestAt            DateTime?
  lastTestStatus        String?   @db.VarChar(20)
  lastTestError         String?   @db.Text

  notes                 String?   @db.Text
  createdById           String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("email_provider_config")
}

/// Permanent audit trail (separate from transient queue rows)
model EmailLog {
  id                String    @id @default(uuid())
  recipientUserId   String?
  recipientEmail    String    @db.VarChar(255)
  eventType         String    @db.VarChar(100)
  templateSlug      String?   @db.VarChar(100)
  templateLanguage  String    @default("en") @db.VarChar(10)
  subject           String    @db.VarChar(500)
  brandingSnapshot  Json?
  language          String    @default("en") @db.VarChar(10)
  provider          String    @default("resend") @db.VarChar(50)
  providerMessageId String?   @db.VarChar(255)
  status            String    @default("queued") @db.VarChar(30) // queued, sent, delivered, failed, bounced
  errorMessage      String?   @db.Text
  metadata          Json?
  idempotencyKey    String?   @unique @db.VarChar(255)
  sentAt            DateTime?
  createdAt         DateTime  @default(now())

  queueId           String?   @unique
  queue             EmailQueue? @relation(fields: [queueId], references: [id], onDelete: SetNull)
  recipient         User?     @relation(fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@index([recipientUserId])
  @@index([eventType])
  @@index([status])
  @@map("email_logs")
}

/// Overrides / extends Tenant + TenantBranding for outbound email
