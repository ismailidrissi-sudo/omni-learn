  assignedBy   String?
  completedAt  DateTime?
  metadata     Json?            @default("{}")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([tenantId])
  @@index([assigneeType, assigneeId])
  @@index([dueDate])
  @@index([status])
}

// ── ENTERPRISE: NOTIFICATIONS ──

model Notification {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String?
  type      String   // "TRAINING_ASSIGNED", "DUE_DATE_APPROACHING", "PATH_COMPLETED", "CERTIFICATE_ISSUED"
  title     String
  body      String?
  isRead    Boolean  @default(false)
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([tenantId])
  @@index([createdAt])
