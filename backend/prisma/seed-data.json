  "forumTopics": [
    { "channelSlug": "general", "title": "Welcome to OmniLearn!", "body": "Welcome to the OmniLearn community. This is a space to connect with peers, share insights, and grow together. Introduce yourself and let us know what you're learning.", "authorEmail": "admin@acme.com" },
    { "channelSlug": "general", "title": "Tips for staying motivated", "body": "What helps you stay on track with your learning goals? I find that setting small daily targets and celebrating small wins keeps me going.", "authorEmail": "learner@acme.com" },
    { "channelSlug": "food-safety", "title": "ISO 22000 implementation checklist", "body": "Has anyone implemented ISO 22000 recently? I'm looking for a practical checklist to share with our team. What were your biggest challenges?", "authorEmail": "trainer@acme.com" },
    { "channelSlug": "food-safety", "title": "HACCP vs ISO 22000", "body": "Can someone explain the key differences between HACCP and ISO 22000? I'm trying to decide which framework fits our operation best.", "authorEmail": "learner@acme.com" },
    { "channelSlug": "implementation", "title": "SOP template feedback", "body": "I've been using the SOP template from the Food Safety course. It's been really helpful for our audit prep. Anyone else have experience with it?", "authorEmail": "trainer@acme.com" },
    { "channelSlug": "implementation", "title": "Monday morning execution tips", "body": "The training was great, but what happens on Monday morning? Share your best tips for turning learning into action on the floor.", "authorEmail": "admin@acme.com" }
  ],
  "forumPosts": [
    { "channelSlug": "general", "topicTitle": "Welcome to OmniLearn!", "body": "Great to be here! I'm starting the Food Safety Professional path. Looking forward to connecting with others on the same journey.", "authorEmail": "learner@acme.com" },
    { "channelSlug": "general", "topicTitle": "Tips for staying motivated", "body": "I use the streak feature — seeing those days add up really motivates me to not break the chain!", "authorEmail": "admin@acme.com" },
    { "channelSlug": "food-safety", "topicTitle": "ISO 22000 implementation checklist", "body": "We completed ours last quarter. The biggest challenge was getting buy-in from production. Start with one pilot area and show quick wins.", "authorEmail": "admin@acme.com" },
    { "channelSlug": "implementation", "topicTitle": "Monday morning execution tips", "body": "We do a 15-minute standup every Monday where each person shares one thing they'll apply from last week's learning. It creates accountability.", "authorEmail": "trainer@acme.com" }
  ]
