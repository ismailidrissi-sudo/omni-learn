# omnilearn.space — Backend Environment
# Afflatus Consulting Group

# ── LOCAL (PostgreSQL via Docker: run `docker compose up -d` from project root) ──
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/omnilearn"

# ── PRODUCTION (set automatically by docker-compose.prod.yml) ──
# DATABASE_URL is built from POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB in root .env
# No need to set DATABASE_URL manually when using Docker.

PORT=4000
NODE_ENV=development

# CORS — comma-separated list of allowed origins (enforced when NODE_ENV=production)
# CORS_ORIGINS="https://omnilearn.space,https://www.omnilearn.space"

# JWT secret (REQUIRED in production — app will refuse to start without it)
JWT_SECRET="generate-a-strong-random-secret-here"

# Dev admin (local only — for /auth/dev-login)
ADMIN_EMAIL=admin@acme.com
ADMIN_PASSWORD=Admin123!

# Google Sign-In (for /auth/google)
# Get from Google Cloud Console: APIs & Services > Credentials > OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID="your-web-client-id.apps.googleusercontent.com"

# LinkedIn Sign-In (for /auth/linkedin)
# Get from LinkedIn Developer Portal: https://www.linkedin.com/developers/apps
# Products → "Sign In with LinkedIn using OpenID Connect"
LINKEDIN_CLIENT_ID="your-linkedin-client-id"
LINKEDIN_CLIENT_SECRET="your-linkedin-client-secret"
# For SPA flow, this is the frontend callback URL; for server flow, the backend callback
LINKEDIN_CALLBACK_URL="http://localhost:3000/auth/linkedin/callback"

# Keycloak SSO
# KEYCLOAK_URL="https://auth.omnilearn.space"
# KEYCLOAK_REALM="omnilearn"
# KEYCLOAK_CLIENT_ID="omnilearn-api"
# JWT_SECRET="..."  # or KEYCLOAK_PUBLIC_KEY for RS256

# Email verification (signup flow)
# SMTP_URL="smtp://user:pass@smtp.example.com:587"
# MAIL_FROM="noreply@omnilearn.space"
# FRONTEND_URL="http://localhost:3000"

# LightFM recommendation service (optional — falls back to embedding-based)
# LIGHTFM_SERVICE_URL="http://localhost:5000"

# Optional — for production
# REDIS_URL="redis://..."
# MEILISEARCH_HOST="https://..."
# MEILISEARCH_API_KEY="..."
# KEYCLOAK_URL="https://..."
