{
  "name": "backend",
  "version": "2.0.0",
  "private": true,
  "prisma": {
    "seed": "npx ts-node prisma/seed.ts"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "prisma:generate": "prisma generate",
    "prisma:generate:local": "prisma generate --schema=prisma/schema.local.prisma",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:local": "prisma migrate dev --schema=prisma/schema.local.prisma --name init",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:setup:local": "prisma generate --schema=prisma/schema.local.prisma && prisma db push --schema=prisma/schema.local.prisma",
    "db:seed": "npx ts-node prisma/seed.ts",
    "db:seed:local": "prisma generate --schema=prisma/schema.local.prisma && npx ts-node prisma/seed.ts"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^16.3.1",
    "nodemailer": "^6.9.8",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/graphql": "^12.2.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@prisma/client": "^5.8.0",
    "apollo-server-express": "^3.13.0",
    "google-auth-library": "^10.6.1",
    "graphql": "^16.8.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "stripe": "^14.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/nodemailer": "^6.4.14",
    "@nestjs/cli": "^10.3.0",
    "@types/node": "^20.10.0",
    "@types/passport-jwt": "^4.0.0",
    "prisma": "^5.8.0",
    "typescript": "^5.3.0"
  }
}
