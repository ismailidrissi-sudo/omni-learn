# omnilearn.space — Video Proxy Service Environment
# Afflatus Consulting Group

# Redis for caching resolved YouTube stream URLs (5h TTL)
REDIS_URL=redis://localhost:6379/0

# yt-dlp configuration
YTDLP_COOKIES_PATH=         # Optional: path to cookies.txt (Netscape format) for authenticated access
YTDLP_BROWSER_COOKIES=      # Optional: browser name to extract cookies from (e.g. chrome, firefox). Non-Docker only.
YTDLP_MAX_QUALITY=720p      # Default max resolution

# Cache TTL
VIDEO_CACHE_TTL_HOURS=5

# Service port
PORT=5001

# Internal service key (must match NestJS backend's INTERNAL_SERVICE_KEY)
INTERNAL_SERVICE_KEY=dev-internal-key
