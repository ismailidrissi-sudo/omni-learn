  "pages": {
    "backToHome": "العودة للرئيسية",
    "terms": {
      "intro": "تحكم شروط الاستخدام هذه في وصولك واستخدامك لـ OmniLearn.space. باستخدام منصتنا، فإنك توافق على هذه الشروط.",
      "section1Title": "قبول الشروط",
      "section1Content": "بالوصول أو استخدام OmniLearn.space، فإنك توافق على الالتزام بشروط الاستخدام وسياسة الخصوصية. إذا كنت لا توافق، يرجى عدم استخدام خدماتنا.",
      "section2Title": "استخدام المنصة",
      "section2Content": "توافق على استخدام المنصة للأغراض القانونية فقط وفقاً لهذه الشروط. لا يجب عليك استخدام المنصة بأي طريقة قد تضر أو تعطل أو تضعف خدماتنا."
    },
    "privacy": {
      "intro": "توضح سياسة الخصوصية هذه كيفية جمع OmniLearn.space ومجموعة Afflatus الاستشارية واستخدام وحماية معلوماتك الشخصية.",
      "section1Title": "المعلومات التي نجمعها",
      "section1Content": "نجمع المعلومات التي تقدمها عند التسجيل أو استخدام منصة التعلم أو الاتصال بنا. قد يشمل ذلك الاسم والبريد الإلكتروني وبيانات تقدم التعلم.",
      "section2Title": "كيف نستخدم معلوماتك",
      "section2Content": "نستخدم معلوماتك لتوفير وتحسين خدماتنا وتخصيص تجربة التعلم والتواصل معك بشأن حسابك."
    },
    "about": {
      "intro": "OmniLearn.space هي المنصة التي تتعلم معك. أنشأتها مجموعة Afflatus الاستشارية لدمقرطة التعلم للجميع.",
      "section1Title": "مهمتنا",
      "section1Content": "نؤمن بأن الوصول إلى التعلم يجب أن يكون حقاً وليس مكافأة. يجمع OmniLearn الدورات المنظمة والتعلم المصغر والبودكاست وأدلة التنفيذ والتلعيب والتعلم الاجتماعي في مساحة واحدة.",
      "section2Title": "أنشأتها Afflatus",
      "section2Content": "تجلب مجموعة Afflatus الاستشارية سنوات من الخبرة الميدانية في الاستشارات والتدقيق والتدريب والتحول عبر الصناعات. كل ميزة ولدت من مشكلة حقيقية."
    },
    "whatWeOffer": {
      "intro": "يقدم OmniLearn نظاماً بيئياً تعليمياً كاملاً مصمماً للمحترفين.",
      "section1Title": "الدورات المنظمة والتعلم المصغر",
      "section1Content": "برامج عميقة يقودها خبراء تبني الإتقان، بالإضافة إلى وحدات قصيرة للتعلم أثناء التنقل. تعلم في التاسعة صباحاً، طبق بحلول الظهر.",
      "section2Title": "البودكاست والأدلة والتعلم الاجتماعي",
      "section2Content": "التعلم الصوتي لرحلتك، أدلة تنفيذ خطوة بخطوة، ومنتديات نقاش بين الأقران. عندما يتعلم شخص واحد، تصبح الشبكة بأكملها أذكى."
    },
    "press": {
      "intro": "استفسارات الصحافة والإعلام لـ OmniLearn.space ومجموعة Afflatus الاستشارية.",
      "section1Title": "مجموعة الوسائط",
      "section1Content": "للشعارات وإرشادات العلامة التجارية ومواد الصحافة، يرجى الاتصال بفريقنا.",
      "section2Title": "الاستفسارات",
      "section2Content": "للاستفسارات الصحفية أو المقابلات أو فرص الشراكة، تواصل معنا عبر صفحة الاتصال."
    },
    "contact": {
      "intro": "تواصل مع فريق OmniLearn. نحن هنا للمساعدة.",
      "section1Title": "الاستفسارات العامة",
      "section1Content": "للأسئلة حول OmniLearn.space أو منصتنا أو كيف يمكننا مساعدة مؤسستك، تواصل معنا عبر نموذج الاتصال أو البريد الإلكتروني.",
      "section2Title": "الدعم",
      "section2Content": "يمكن للعملاء الحاليين الوصول إلى الدعم عبر لوحة التحكم أو بالاتصال بمدير الحساب."
    },
    "modernSlavery": {
      "intro": "تلتزم OmniLearn.space ومجموعة Afflatus الاستشارية بممارسات الأعمال الأخلاقية والقضاء على العبودية الحديثة والاتجار بالبشر.",
      "section1Title": "التزامنا",
      "section1Content": "نلتزم بضمان خلو عملياتنا وسلاسل التوريد من العبودية الحديثة والاتجار بالبشر والعمل القسري. نتوقع نفس المعايير من شركائنا وموردينا.",
      "section2Title": "العناية الواجبة",
      "section2Content": "نجري العناية الواجبة على سلسلة التوريد وشركاء الأعمال لتحديد وتخفيف المخاطر المتعلقة بالعبودية الحديثة. نراجع ونحدث ممارساتنا سنوياً."
    }
  },
