# omnilearn.space — Production Environment Variables
# Copy to .env and fill in real values before running docker-compose.prod.yml
# On the VPS: cp .env.example .env && nano .env

# ── Database (used by docker-compose to create the PostgreSQL container) ──
POSTGRES_USER=omnilearn
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=omnilearn

# ── Backend ──
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
CORS_ORIGINS=https://omnilearn.space,https://www.omnilearn.space
FRONTEND_URL=https://omnilearn.space
# First super-admin (create clients / full admin). Set and log in once to get super-admin access.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── SSO: Google Sign-In ──
# Get from Google Cloud Console: APIs & Services > Credentials > OAuth 2.0 Client ID (Web)
# Authorized JavaScript origins: https://omnilearn.space
# Authorized redirect URIs: https://omnilearn.space
GOOGLE_CLIENT_ID=

# ── SSO: LinkedIn Sign-In ──
# Get from LinkedIn Developer Portal: https://www.linkedin.com/developers/apps
# Products: enable "Sign In with LinkedIn using OpenID Connect"
# Auth > Authorized redirect URLs: https://omnilearn.space/auth/linkedin/callback
#                                   https://omnilearn.space/api/auth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=https://omnilearn.space/auth/linkedin/callback
LINKEDIN_SERVER_CALLBACK_URL=https://omnilearn.space/api/auth/linkedin/callback

# Email (Resend queue system — managed from admin panel)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_ENCRYPTION_KEY=CHANGE_ME_generate_with_node_crypto
MAIL_FROM=noreply@omnilearn.space

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── LightFM Recommendations (internal service-to-service key) ──
# Generate with: openssl rand -hex 32
INTERNAL_SERVICE_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Video Proxy (yt-dlp YouTube resolution) ──
YTDLP_MAX_QUALITY=720p
YTDLP_COOKIES_PATH=          # Path to cookies.txt (Netscape format) inside the container
YTDLP_BROWSER_COOKIES=       # Browser name for cookie extraction (chrome/firefox). Non-Docker only.

# ── Frontend (baked into the Docker image at build time) ──
NEXT_PUBLIC_API_URL=https://omnilearn.space/api
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_LINKEDIN_CLIENT_ID=
